# Resend — contact form email delivery (https://resend.com)
RESEND_API_KEY=

# Gemini — portfolio chatbot (https://aistudio.google.com/apikey)
# Single key:
GEMINI_API_KEY=
# Or multiple keys (comma-separated) for quota failover — takes priority:
# GEMINI_API_KEYS=key1,key2,key3

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# Leave DATABASE_URL empty to run the site on built-in mock data.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
# DIRECT_URL is only needed when DATABASE_URL points at a connection pooler
# (e.g. Supabase/Neon pgbouncer) — set it to the direct, non-pooled URL.
# ---------------------------------------------------------------------------
DATABASE_URL=
DIRECT_URL=

# ---------------------------------------------------------------------------
# Cloudinary — image hosting & uploads for the admin panel
# (https://cloudinary.com/console)
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Public cloud name used by the browser (next/image, upload widget)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ---------------------------------------------------------------------------
# Admin auth (Auth.js)
# AUTH_SECRET: generate with `npx auth secret`
# ADMIN_EMAIL / ADMIN_PASSWORD: used once by `npm run db:seed` to create the
# initial admin user (remove afterwards).
# ---------------------------------------------------------------------------
AUTH_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=
